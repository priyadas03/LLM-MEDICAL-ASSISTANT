PORT=3001
NODE_ENV=development

# LLM provider: "mock" (default) or later "openai"
LLM_PROVIDER=mock

# Used for PHI encryption-at-rest (required when you start storing PHI long-term).
# For local development you can set any 32-byte base64 / hex key.
PHI_ENC_KEY=

# Prisma connection string (SQLite by default)
DATABASE_URL="file:./dev.db"

# Where to find the local source index (used by RAG)
SOURCE_INDEX_PATH="./data/vector_index/index.json"

